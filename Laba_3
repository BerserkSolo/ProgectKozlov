// ЧАСТЬ 3: BFS 
// ЧАСТЬ 3.1.1 БЕЗ МОДИФИКАЦИИ (плоскость) — для массива

//вверх, вниз, влево, вправо
const int DX[4] = { -1, 1, 0, 0 };
const int DY[4] = { 0, 0, -1, 1 };

int countComponents(int M, int N, const vector<vector<bool>>& grid) {
    //создаем такой же массив как и grid, где все false, то есть еще не посетили ни одного элемента
    vector<vector<bool>> visited(M, vector<bool>(N, false));
    int components = 0; // куски

    for (int i = 0; i < M; i++) {
        for (int j = 0; j < N; j++) {
            if (!grid[i][j] || visited[i][j]) continue; // если в grid сетка удалена, то пропускаем ее

            components++;
            ArrayQueue q(M * N);
            visited[i][j] = true; // пометили первый элемент
            q.push({ i, j });//добавили элемент

            while (!q.empty()) {
                pair<int, int> current = q.front();
                q.pop();
                int x = current.first;
                int y = current.second;

                for (int d = 0; d < 4; d++) {
                    int nx = x + DX[d];
                    int ny = y + DY[d];

                    //!!! Проверка границы. Если за нею, то пропускаем
                    if (nx < 0 || nx >= M || ny < 0 || ny >= N) continue;
                    //если есть клетка, и мы ее еще не защищали, то помечаем ее и добавляем в конец
                    if (grid[nx][ny] && !visited[nx][ny]) {
                        visited[nx][ny] = true;
                        q.push({ nx, ny });
                    }
                }
            }
        }
    }

    return components; //выводим кол-во кусков
}


//============================================================================
// ЧАСТЬ 3.1.2: BFS С МОДИФИКАЦИЕЙ (ЦИЛИНДР) — для массива

// ЦИЛИНДР: левый и правый край склеены
// Стоит понимать, что по горизонтали крайние клетки стали соседемя, а по вертикали ничего не меняется. Приходим к выводу, что код будет 
// аналогичный, а точнее такм же кромепроверки(теперь только вертикаль) + используем формулы для корректной работы с координатами
// Координата y (столбец) работает по кругу: y = (y % N + N) % N

int countComponentsCylinder(int M, int N, const vector<vector<bool>>& grid) {
    //создаем такой же массив как и grid, где все false
    vector<vector<bool>> visited(M, vector<bool>(N, false));
    int components = 0; // куски

    for (int i = 0; i < M; i++) {
        for (int j = 0; j < N; j++) {
            if (!grid[i][j] || visited[i][j]) continue; // если удалена или посещена - пропускаем

            components++;
            ArrayQueue q(M * N);
            visited[i][j] = true; // пометили стартовую
            q.push({ i, j });//добавили в очередь

            while (!q.empty()) {
                pair<int, int> current = q.front();
                q.pop();
                int x = current.first;
                int y = current.second;

                //проверяем четырех соседей
                for (int d = 0; d < 4; d++) {
                    int nx = x + DX[d];
                    int ny = y + DY[d];

                    //!!! Проверка ВЕРТИКАЛЬНЫХ границ (вверх/вниз) - как на плоскости
                    if (nx < 0 || nx >= M) continue;

                    //!!!
                    int nyCyl = ((ny % N) + N) % N;

                    // Проверяем соседа с цилиндрической координатой
                    if (grid[nx][nyCyl] && !visited[nx][nyCyl]) {
                        visited[nx][nyCyl] = true;
                        q.push({ nx, ny }); // в очередь кладем оригинальные координаты (для проверки соседей)
                    }
                }
            }
        }
    }

    return components; //выводим кол-во кусков
}


