// ЧАСТЬ 4: СРАВНЕНИЕ ПРОИЗВОДИТЕЛЬНОСТИ

// Замеряем время выполнения каждой реализации для одной и той же сетки.
void benchmark(int M, int N, const vector<vector<bool>>& grid, int runs) {
    cout << endl << "=== PERFORMANCE COMPARISON ===" << endl;
    cout << "Grid size: " << M << "x" << N << ", runs: " << runs << endl << endl;

    // --- Пункт А: Массив ---
    auto start = chrono::high_resolution_clock::now();
    for (int r = 0; r < runs; r++) {
        countComponents(M, N, grid);
    }
    auto end = chrono::high_resolution_clock::now();
    auto timeArray = chrono::duration<double, milli>(end - start).count();

    // --- Пункт Б: Связный список ---
    start = chrono::high_resolution_clock::now();
    for (int r = 0; r < runs; r++) {
        countComponentsList(M, N, grid);
    }
    end = chrono::high_resolution_clock::now();
    auto timeList = chrono::duration<double, milli>(end - start).count();

    // --- Пункт В: STL ---
    start = chrono::high_resolution_clock::now();
    for (int r = 0; r < runs; r++) {
        countComponentsSTL(M, N, grid);
    }
    end = chrono::high_resolution_clock::now();
    auto timeSTL = chrono::duration<double, milli>(end - start).count();

    // Вывод результатов
    cout << "Array (A):      " << timeArray << " ms" << endl;
    cout << "List (B):       " << timeList << " ms" << endl;
    cout << "STL (V):        " << timeSTL << " ms" << endl;

    cout << endl << "Conclusion:" << endl;
    if (timeArray <= timeList && timeArray <= timeSTL)
        cout << "Array is the fastest " << endl;
    if (timeSTL <= timeArray && timeSTL <= timeList)
        cout << "STL is the fastest " << endl;
    if (timeList <= timeArray && timeList <= timeSTL)
        cout << "List is fastest " << endl;
}


