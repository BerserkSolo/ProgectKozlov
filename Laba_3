//  ЧАСТЬ 2.1: ОЧЕРЕДЬ ЧЕРЕЗ МАССИВ (ПУНКТ А)
class ArrayQueue {
private:
    pair<int, int>* data;
    int capacity;
    int head;
    int tail;
    int count; // кол-во элементов в очерреди
public:
    ArrayQueue(int maxSize) { // maxSize = M * N в maine
        capacity = maxSize; // запоминаем размер
        data = new pair<int, int>[capacity]; // просим операциооную сист выделить память для очереди
        head = 0;
        tail = 0;
        count = 0;
    }

    ~ArrayQueue() { // используем диструктор для отчистки памяти после того, как прошли очередь
        delete[] data;
    }

    void push(pair<int, int> value) {//добавляем в конец новую пару
        data[tail] = value;
        tail = (tail + 1) % capacity; // !!! ДЕЛИМ на capacity чтобы "закольцевать" очередь
        count++; // так как довили элемент 
    }

    void pop() {   // пеередвигаем ead, "удаляеем" элемент из очереди
        head = (head + 1) % capacity;
        count--; // так как обаботали один элемент 
    }

    pair<int, int> front() { // смотрим какой элемент
        return data[head];
    }

    bool empty() { // проверка на "пустоту" очереди, нужно жля while()
        return count == 0;
    }
};


// ===========================================================================
// ЧАСТЬ 2.2: ОЧЕРЕДЬ ЧЕРЕЗ СВЯЗНЫЙ СПИСОК (ПУНКТ Б)
// Вместо массива — цепочка узлов

class ListQueue {
private:
    // Узел — элемент цепочки
    struct Node {
        pair<int, int> value;   // координаты клетки (x, y)
        Node* next;              // указатель на следующий узел

        Node(pair<int, int> v) { // конструктор узла
            value = v;
            next = nullptr;       // пока нет следующего
        }
    };

    Node* head;   // начало очереди (откуда забираем)
    Node* tail;   // конец очереди (куда кладём)
    int count;    // количество элементов

public:
    ListQueue() {    // конструктор — пустая очередь
        head = nullptr;
        tail = nullptr;
        count = 0;
    }

    ~ListQueue() {   // деструктор — удаляем ВСЕ узлы, иначе утечка памяти!
        while (head != nullptr) {
            Node* temp = head;      // запомнили текущий
            head = head->next;      // сдвинули на следующий
            delete temp;            // удалили старый
        }
    }

    void push(pair<int, int> value) { // добавляем в конец
        Node* newNode = new Node(value); // создали новый узел в памяти

        if (tail == nullptr) {          // очередь была пуста
            head = tail = newNode;       // и head, и tail на него
        }
        else {                         // очередь не пуста
            tail->next = newNode;        // старый tail ссылается на новый
            tail = newNode;              // tail теперь на новый
        }
        count++;
    }

    void pop() { // удаляем из начала
        if (empty()) return;

        Node* temp = head;      // запомнили старый head
        head = head->next;      // сдвинули head
        delete temp;            // удалили узел из памяти!
        count--;

        if (head == nullptr) {  // удалили последний элемент
            tail = nullptr;     // tail тоже nullptr
        }
    }

    pair<int, int> front() { // смотрим первый элемент
        return head->value;
    }

    bool empty() { // проверка на пустоту
        return head == nullptr;
    }
};


