struct Node {
    std::string symbol;
    int8_t      count;
    Node*       next = nullptr;
};

class SymbolFrequencyTable {
    static constexpr size_t INITIAL_BUCKET_COUNT = 64;
    Node** bucket_array = nullptr;
    size_t bucket_count = 0;
    size_t element_count = 0;

    static size_t compute_hash(const std::string& text) {
        size_t hash_value = 14695981039346656037ULL;
        for (unsigned char byte : text) {
            hash_value ^= byte;
            hash_value *= 1099511628211ULL;
        }
        return hash_value;
    }

    void expand_and_rehash() {
        size_t new_bucket_count = bucket_count * 2;
        Node** new_buckets = new Node * [new_bucket_count]();
        for (size_t i = 0; i < bucket_count; ++i) {
            for (Node* current = bucket_array[i]; current;) {
                Node* next_node = current->next;
                size_t new_index = compute_hash(current->symbol) & (new_bucket_count - 1);
                current->next = new_buckets[new_index];
                new_buckets[new_index] = current;
                current = next_node;
            }
        }
        delete[] bucket_array;
        bucket_array = new_buckets;
        bucket_count = new_bucket_count;
    }

public:
    SymbolFrequencyTable() : bucket_count(INITIAL_BUCKET_COUNT), element_count(0) {
        bucket_array = new Node * [INITIAL_BUCKET_COUNT]();
    }

    ~SymbolFrequencyTable() { clear(); delete[] bucket_array; }

    SymbolFrequencyTable(const SymbolFrequencyTable&) = delete;
    SymbolFrequencyTable& operator=(const SymbolFrequencyTable&) = delete;

    SymbolFrequencyTable(SymbolFrequencyTable&& other) noexcept
        : bucket_array(other.bucket_array),
          bucket_count(other.bucket_count),
          element_count(other.element_count) {
        other.bucket_array = nullptr;
        other.bucket_count = other.element_count = 0;
    }

    SymbolFrequencyTable& operator=(SymbolFrequencyTable&& other) noexcept {
        if (this != &other) {
            clear();
            delete[] bucket_array;
            bucket_array = other.bucket_array;
            bucket_count = other.bucket_count;
            element_count = other.element_count;
            other.bucket_array = nullptr;
            other.bucket_count = other.element_count = 0;
        }
        return *this;
    }

    void clear() {
        for (size_t i = 0; i < bucket_count; ++i) {
            for (Node* current = bucket_array[i]; current;) {
                Node* temp = current->next;
                delete current;
                current = temp;
            }
            bucket_array[i] = nullptr;
        }
        element_count = 0;
    }

    void add_symbol(const std::string& symbol) {
        if (element_count * 4 >= bucket_count * 3)
            expand_and_rehash();
        size_t index = compute_hash(symbol) & (bucket_count - 1);
        for (Node* current = bucket_array[index]; current; current = current->next)
            if (current->symbol == symbol) {
                ++current->count;
                return;
            }
        bucket_array[index] = new Node{ symbol, 1, bucket_array[index] };
        ++element_count;
    }

    int8_t get_frequency(const std::string& symbol) const {
        size_t index = compute_hash(symbol) & (bucket_count - 1);
        for (Node* current = bucket_array[index]; current; current = current->next)
            if (current->symbol == symbol)
                return current->count;
        return 0;
    }

    template<typename Action>
    void for_each_symbol(Action&& action) const {
        for (size_t i = 0; i < bucket_count; ++i)
            for (Node* current = bucket_array[i]; current; current = current->next)
                action(current->symbol, current->count);
    }
};

struct DictionaryWord {
    std::string text;
    SymbolFrequencyTable symbol_counts;
    int byte_length;
    int char_length;
};

